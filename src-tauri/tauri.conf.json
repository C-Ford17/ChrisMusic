{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ChrisMusic",
  "version": "1.0.8",
  "identifier": "com.chrismusic.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ChrisMusic",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:3000; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https: http: asset:; media-src 'self' blob: https: http: asset: asset://* http://asset.localhost; connect-src 'self' http://localhost:3000 https: http:;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$LOCALDATA/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/C-Ford17/ChrisMusic/main/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCQTkwRUJFMTJFRkE2QzYKUldUR3B1OFN2ZzZwS3gyenp2OUdCRUhSWHpHd0xad2cvaFFJTjRzMStvVFErU015MkxFMkVGclkK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../cookies.txt"
    ],
    "externalBin": [
      "binaries/yt-dlp"
    ]
  }
}