{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default app capability",
  "platforms": [
    "linux",
    "windows",
    "macOS"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    "core:path:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "yt-dlp",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "fs:default",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "http:default",
    "http:allow-fetch",
    "allow-search-youtube-native-cmd",
    "allow-get-streaming-url",
    "allow-download-to-disk",
    "allow-test-ytdlp"
  ]
}