{
    "$schema": "../gen/schemas/mobile-schema.json",
    "identifier": "mobile-default",
    "description": "Mobile capability",
    "platforms": [
        "android",
        "iOS"
    ],
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        "core:path:default",
        "fs:default",
        "fs:allow-appdata-read-recursive",
        "fs:allow-appdata-write-recursive",
        "http:default",
        {
            "identifier": "http:allow-fetch",
            "allow": [
                {
                    "url": "https://suggestqueries.google.com/complete/search*"
                },
                {
                    "url": "https://*.googlevideo.com/*"
                },
                {
                    "url": "https://*.googleusercontent.com/*"
                },
                {
                    "url": "https://i.ytimg.com/*"
                }
            ]
        },
        "allow-search-youtube-native-cmd",
        "allow-get-streaming-url",
        "allow-download-to-disk",
        "allow-test-ytdlp",
        "allow-get-artist-details-cmd",
        "allow-get-album-details-cmd"
    ]
}